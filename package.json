        "@types/eslint__js": "^9.14.0",
        "@types/express": "^5.0.6",
        "@types/node": "^25.6.0",
        "@types/source-map-support": "^0.5.10",
        "eslint": "^10.2.0",
        "eslint-config-prettier": "^10.1.8",
        "husky": "^9.1.7",
        "lint-staged": "^16.4.0",
        "nodemon": "^3.1.14",
        "prettier": "3.8.2",
        "ts-node": "^10.9.2",
        "tsc-alias": "^1.8.16",
